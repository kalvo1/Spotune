<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Spotune" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Black background for app -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item> <!-- White icons -->
        <item name="android:windowLightNavigationBar">false</item> <!-- White icons -->

        <!-- Splash screen theme -->
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_logo_512</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@null</item>
    </style>
    <style name="Theme.Spotune.Splash" parent="Theme.Spotune">
        <item name="postSplashScreenTheme">@style/Theme.Spotune</item>
    </style>
</resources>